{
  "custom": {},
  "params": {
    "groupName": "",
    "inputAttributes": [],
    "outputAttributes": []
  },
  "propConfig": {
    "params.groupName": {
      "binding": {
        "config": {
          "bidirectional": true,
          "path": "/root/Header/GroupName.props.text"
        },
        "type": "property"
      },
      "paramDirection": "inout",
      "persistent": true
    },
    "params.inputAttributes": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.outputAttributes": {
      "binding": {
        "config": {
          "path": "/root/AttributeList.props.instances"
        },
        "transforms": [
          {
            "code": "\tinstances\u003dsystem.util.jsonDecode(system.util.jsonEncode(value))\n\tcleaned\u003dself.view.getChild(\"root\").cleanAttributes(instances)\n\treturn cleaned",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "paramDirection": "output",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 432,
      "width": 453
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "GroupName"
            },
            "position": {
              "basis": "150px",
              "grow": 1
            },
            "props": {
              "placeholder": "Group Name...",
              "style": {
                "margin": "2px"
              }
            },
            "type": "ia.input.text-field"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\tself.parent.parent.getChild(\"AttributeList\").props.instances.append({\n\t\t  \"key\": \"\",\n\t\t  \"value\": \"\",\n\t\t  \"datatype\": None\n\t\t})"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "Add Attribute"
            },
            "props": {
              "image": {
                "icon": {
                  "path": "material/add_circle"
                }
              },
              "style": {
                "classes": "ButtonStyles/GeneralHover"
              },
              "text": "Add Attribute"
            },
            "type": "ia.input.button"
          },
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "script": "\tinstances\u003dsystem.util.jsonDecode(system.util.jsonEncode(self.parent.parent.getChild(\"AttributeList\").props.instances))\n\tcleaned\u003dself.view.getChild(\"root\").cleanAttributes(instances)\n\tself.parent.parent.getChild(\"AttributeList\").props.instances\u003dcleaned"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "Refresh"
            },
            "position": {
              "basis": "30px"
            },
            "props": {
              "path": "material/refresh",
              "style": {
                "classes": "ButtonStyles/IconHover"
              }
            },
            "type": "ia.display.icon"
          }
        ],
        "meta": {
          "name": "Header"
        },
        "position": {
          "basis": "35px",
          "shrink": 0
        },
        "props": {
          "justify": "space-between"
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "AttributeList"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "props.instances": {
            "binding": {
              "config": {
                "path": "view.params.inputAttributes"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "direction": "column",
          "elementPosition": {
            "basis": "32px",
            "grow": 0,
            "shrink": 0
          },
          "path": "Templates/Attribute",
          "useDefaultViewHeight": false,
          "useDefaultViewWidth": false
        },
        "type": "ia.display.flex-repeater"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "Subviews/Cards"
      }
    },
    "scripts": {
      "customMethods": [
        {
          "name": "cleanAttributes",
          "params": [
            "instances"
          ],
          "script": "\tif not instances:\n\t\treturn []\n\treturn [inst for inst in instances if inst.get(\u0027key\u0027) !\u003d \"\"]\n\t"
        }
      ],
      "extensionFunctions": null,
      "messageHandlers": []
    },
    "type": "ia.container.flex"
  }
}