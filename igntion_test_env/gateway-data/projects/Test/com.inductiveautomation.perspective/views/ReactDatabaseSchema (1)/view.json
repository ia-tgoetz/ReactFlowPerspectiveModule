                    {
                      "code": "\t# Convert raw dataset to PyDataSet for easy looping\n\tdata \u003d system.dataset.toPyDataSet(system.db.getConnections())\n\toptions \u003d []\n\tfor row in data:\n\t    # Only include \u0027Valid\u0027 connections if desired\n#\t    if row[\"Status\"] \u003d\u003d \"Valid\":\n#\t        options.append({\n#\t            \"value\": row[\"Name\"],\n#\t            \"label\": row[\"Name\"]\n#\t        })\n\t\tisDisabled\u003dTrue\n\t\tif row[\"Status\"] \u003d\u003d \"Valid\":\n\t\t\tisDisabled\u003dFalse\n\t\toptions.append({\n\t\t    \"value\": row[\"Name\"],\n\t\t    \"label\": row[\"Name\"],\n\t\t    \"isDisabled\": isDisabled\n\t\t})\n\treturn options",
                      "type": "script"
                    }
                  ],
                  "type": "expr"
                }
              },
              "props.placeholder.text": {
                "binding": {
                  "config": {
                    "expression": " \"Select History Provider (\"+len({this.props.options}) + \" available)...\""
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "placeholder": {},
              "showClearIcon": true,
              "style": {
                "margin": "2px"
              },
              "value": "mesIgnition"
            },
