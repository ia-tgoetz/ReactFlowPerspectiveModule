                  "config": {
                    "script": "\tself.parent.parent.getChild(\"dbSchema\").props.tables\u003dself.parent.custom.schema.tables\n\tself.parent.parent.getChild(\"dbSchema\").props.relationships\u003dself.parent.custom.schema.relationships"
                  },
