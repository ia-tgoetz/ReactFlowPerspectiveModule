            "events": {
              "component": {
                "onFileReceived": {
                  "config": {
                    "script": "\t\n\timport base64\n\t\n\tdef convert_svg_to_markdown(svg_string):\n\t    \"\"\"\n\t    Takes a raw SVG string, encodes it to Base64, and returns \n\t    the fully formatted Markdown image string.\n\t    \"\"\"\n\t    # 1. Encode the raw string into Base64\n\t    # We encode to utf-8 first to ensure any special characters are handled correctly\n\t    encoded_bytes \u003d base64.b64encode(svg_string.encode(\u0027utf-8\u0027))\n\t    \n\t    # In Jython 2.7, b64encode returns a string, but it\u0027s safe to cast just in case\n\t    base64_string \u003d str(encoded_bytes)\n\t    \n\t    # 2. Construct the Data URI and Markdown syntax\n\t    markdown_output \u003d \"data:image/svg+xml;base64,\" + base64_string\n\t    \n\t    return markdown_output\n\t\n\t# --- TEST IT OUT ---\n\t\n\t# Paste your exact SVG string inside the triple quotes\n\tmy_raw_svg \u003d \"\"\"{}\"\"\".format(event.file.getString())\n\t\n\t# Run the function\n\tself.view.params.paletteItem.b64Image\u003dconvert_svg_to_markdown(my_raw_svg)\n\t\n\t# Print the result so you can copy and paste it into your Markdown component\n"
                  },
                  "scope": "G",
                  "type": "script"
                },
                "onUploadsCleared": {
                  "config": {
                    "script": "\tself.view.params.paletteItem.b64Image\u003d\"\""
                  },
                  "scope": "G",
                  "type": "script"
                }
