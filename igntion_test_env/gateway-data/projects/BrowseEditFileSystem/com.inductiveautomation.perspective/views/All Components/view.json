{
  "custom": {},
  "params": {},
  "props": {
    "defaultSize": {
      "width": 848
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "TextArea"
        },
        "position": {
          "basis": "160px",
          "shrink": 0
        },
        "props": {
          "text": {
            "action": "config",
            "id": "key",
            "paletteId": "gateway",
            "type": "node"
          }
        },
        "type": "ia.input.text-area"
      },
      {
        "children": [
          {
            "meta": {
              "name": "Checkbox"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.selected": {
                "binding": {
                  "config": {
                    "bidirectional": true,
                    "path": ".../ArchitectureBuilder.props.hideHandles"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "marginLeft": "16px"
              },
              "text": "hideHandles"
            },
            "type": "ia.input.checkbox"
          },
          {
            "meta": {
              "name": "Checkbox_0"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.selected": {
                "binding": {
                  "config": {
                    "bidirectional": true,
                    "path": ".../ArchitectureBuilder.props.snapEnabled"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "marginLeft": "16px"
              },
              "text": "snapping"
            },
            "type": "ia.input.checkbox"
          },
          {
            "meta": {
              "name": "NumericEntryField"
            },
            "position": {
              "basis": "150px"
            },
            "propConfig": {
              "props.value": {
                "binding": {
                  "config": {
                    "bidirectional": true,
                    "path": ".../ArchitectureBuilder.props.snapPixels"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "spinner": {
                "enabled": false
              },
              "style": {
                "marginLeft": "16px"
              }
            },
            "type": "ia.input.numeric-entry-field"
          }
        ],
        "meta": {
          "name": "FlexContainer"
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "ArchitectureBuilder"
        },
        "position": {
          "basis": "600px"
        },
        "props": {
          "snapEnabled": false,
          "snapPixels": 30
        },
        "type": "com.wargoetz.reactflow.architecturebuilder"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column"
    },
    "type": "ia.container.flex"
  }
}