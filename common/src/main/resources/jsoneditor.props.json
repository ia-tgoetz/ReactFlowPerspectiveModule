{
    "type": "object",
    "properties": {
        "data": {
            "type": "object",
            "description": "The JSON object to display or edit.",
            "default": {}
        },
        "theme": {
            "type": "string",
            "description": "Select a standard built-in theme.",
            "enum": [
                "apathy", "async", "blackboard", "brewer", "bright", "chalk", 
                "codeschool", "colors", "eighties", "embers", "flat", "google", 
                "grayscale", "greenscreen", "hopscotch", "isotope", "marrakesh", 
                "mocha", "monokai", "ocean", "paraiso", "pop", "railscasts", 
                "rgh", "shapeshifter", "solarized", "summerfruit", "tomorrow", 
                "tube", "twilight"
            ],
            "default": "monokai"
        },
        "customTheme": {
            "type": "object",
            "properties": {
                "backgroundColor": { "type": "string" },
                "keyColor": { "type": "string" },
                "stringColor": { "type": "string" },
                "numberColor": { "type": "string" },
                "booleanColor": { "type": "string" },
                "bracketColor": { "type": "string" }
            },
            "default": {}
        },
        "editable": { "type": "boolean", "default": true },
        "style": {
            "$ref": "urn:ignition-schema:schemas/style-properties.schema.json"
        }
    }
}