{
  "type": "object",
  "properties": {
    "tables": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Unique identifier for this table." },
          "name": { "type": "string", "description": "The display name of the table." },
          "columns": { "type": "array", "items": { "type": "string" }, "description": "List of column names in the table." },
          "headerStyle": { 
            "$ref": "urn:ignition-schema:schemas/style-properties.schema.json",
            "description": "Overrides the CSS header theme for this specific table." 
          },
          "rowStyle": { 
            "$ref": "urn:ignition-schema:schemas/style-properties.schema.json",
            "description": "Overrides the CSS background theme for this specific table." 
          },
          "position": {
            "type": "object",
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" }
            },
            "description": "Canvas coordinates. Updates automatically when dragged."
          }
        }
      },
      "default": [
        {
          "id": "sqlth_partitions",
          "name": "sqlth_partitions",
          "columns": ["pname", "drvid", "start_time", "end_time", "blocksize", "flags"],
          "headerStyle": {},
          "rowStyle": {},
          "position": { "x": 0, "y": 0 }
        },
        {
          "id": "sqlth_data",
          "name": "sqlth_data_(drvid)_(date)",
          "columns": ["tagid", "intvalue", "floatvalue", "stringvalue", "datevalue", "dataintegrity", "t_stamp"],
          "headerStyle": {},
          "rowStyle": {},
          "position": { "x": 350, "y": 0 }
        },
        {
          "id": "sqlth_te",
          "name": "sqlth_te",
          "columns": ["id", "tagpath", "scid", "datatype", "querymode", "created", "retired"],
          "headerStyle": {},
          "rowStyle": {},
          "position": { "x": 700, "y": 0 }
        },
        {
          "id": "sqlth_sce",
          "name": "sqlth_sce",
          "columns": ["scid", "start_time", "end_time", "rate"],
          "headerStyle": {},
          "rowStyle": {},
          "position": { "x": 0, "y": 300 }
        },
        {
          "id": "sqlth_scinfo",
          "name": "sqlth_scinfo",
          "columns": ["id", "scname", "drvid"],
          "headerStyle": {},
          "rowStyle": {},
          "position": { "x": 350, "y": 300 }
        },
        {
          "id": "sqlth_drv",
          "name": "sqlth_drv",
          "columns": ["id", "name", "provider"],
          "headerStyle": {},
          "rowStyle": {},
          "position": { "x": 700, "y": 300 }
        }
      ]
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source": { "type": "string", "description": "The ID of the source table." },
          "sourceColumn": { "type": "string", "description": "Column to connect to. Leave blank to connect to the table globally." },
          "target": { "type": "string", "description": "The ID of the target table." },
          "targetColumn": { "type": "string", "description": "Column to connect to. Leave blank to connect to the table globally." },
          "type": { 
            "type": "string", 
            "enum": ["one-to-many", "many-to-one", "one-to-one", "none"],
            "description": "Visual flow of the relationship. Text labels are hidden." 
          },
          "lineType": { 
            "type": "string", 
            "enum": ["default", "smoothstep", "step", "straight"],
            "description": "The geometric path style the line will draw."
          },
          "lineColor": { "type": "string", "description": "Hex, CSS color, or Theme Variable (e.g., var(--callToAction))." },
          "lineWidth": { "type": "number", "description": "Thickness of the connection line." },
          "style": { 
            "$ref": "urn:ignition-schema:schemas/style-properties.schema.json",
            "description": "Additional CSS for the line (e.g., strokeDasharray)." 
          }
        }
      },
      "default": [
        { "source": "sqlth_partitions", "sourceColumn": "pname", "target": "sqlth_data", "targetColumn": "", "type": "one-to-many", "lineType": "default" },
        { "source": "sqlth_partitions", "sourceColumn": "drvid", "target": "sqlth_drv", "targetColumn": "id", "type": "many-to-one", "lineType": "default" },
        { "source": "sqlth_data", "sourceColumn": "tagid", "target": "sqlth_te", "targetColumn": "id", "type": "many-to-one", "lineType": "default" },
        { "source": "sqlth_te", "sourceColumn": "scid", "target": "sqlth_scinfo", "targetColumn": "id", "type": "many-to-one", "lineType": "default" },
        { "source": "sqlth_sce", "sourceColumn": "scid", "target": "sqlth_scinfo", "targetColumn": "id", "type": "many-to-one", "lineType": "default" },
        { "source": "sqlth_scinfo", "sourceColumn": "drvid", "target": "sqlth_drv", "targetColumn": "id", "type": "many-to-one", "lineType": "default" }
      ]
    }
  }
}